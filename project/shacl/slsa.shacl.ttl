@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix slsa: <https://w3id.org/lmodel/slsa/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

slsa:BuildEnvironmentAttestation a sh:NodeShape ;
    rdfs:comment "An attestation describing the integrity of a build environment at the time a specific build was dispatched and executed. Used to verify that a build ran in the expected, untampered environment." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The SLSA Build Environment Level supported or represented, reflecting the strength of the integrity guarantees provided." ;
            sh:in ( "SLSA_BUILD_ENV_LEVEL_0" "SLSA_BUILD_ENV_LEVEL_1" "SLSA_BUILD_ENV_LEVEL_2" "SLSA_BUILD_ENV_LEVEL_3" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path slsa:buildEnvLevel ],
        [ sh:datatype xsd:string ;
            sh:description "URI or name of the tool used to cryptographically sign the artifact or attestation (e.g., \"https://github.com/sigstore/cosign\", \"https://github.com/notaryproject/notation\"). In the SSF reference architecture the Signing Service layer is distinct from the Build Service; recording the signing tool enables verifiers to select the matching verification workflow. For Sigstore keyless signing the value should be the Cosign release URI." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path slsa:signingTool ],
        [ sh:class slsa:ResourceDescriptor ;
            sh:description "The set of software artifacts to which a predicate applies. Each entry MUST contain a digest." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path slsa:subject ],
        [ sh:datatype xsd:string ;
            sh:description "Cryptographic measurements (hashes) of build environment components captured during boot and initialization, used to verify integrity against known-good reference values." ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path slsa:measurements ],
        [ sh:datatype xsd:string ;
            sh:description "An immutable identifier uniquely assigned to a build execution (e.g., a UUID). Links a BuildEnvironmentAttestation to the corresponding build provenance." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path slsa:buildId ],
        [ sh:datatype xsd:string ;
            sh:description "URI indicating where this signed attestation is publicly stored or retrievable. No universal standard for attestation storage location was established in SLSA v1.0; Sigstore and VCS-embedded storage are two common approaches. Explicitly recording this URI addresses the storage ambiguity identified as a significant adoption barrier: practitioners reported uncertainty about where generated attestations should be stored (Tamanna et al., 2024, LF.1)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path slsa:attestationStorageUri ],
        [ sh:datatype xsd:string ;
            sh:description "Always \"https://in-toto.io/Statement/v1\". Identifies the in-toto statement schema version and namespace." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path slsa:_type ],
        [ sh:datatype xsd:string ;
            sh:description "URI identifying the schema and semantics of the predicate field. Used to distinguish different attestation types (e.g., SLSA Provenance vs. Verification Summary Attestation)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path slsa:predicateType ],
        [ sh:class slsa:BuildImage ;
            sh:description "The build image from which the build environment was instantiated." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path slsa:buildImage ],
        [ sh:datatype xsd:string ;
            sh:description "The attestation payload — an arbitrary JSON object whose schema is fully determined by predicateType." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path slsa:predicate ],
        [ sh:datatype xsd:string ;
            sh:description "URI of the Rekor transparency log entry recording this attestation or artifact signature (e.g., \"https://rekor.sigstore.dev/api/v1/log/entries/24296fb...\"). The Rekor log provides an immutable, auditable record of signing events that underpins Sigstore keyless signing. Verifiers can fetch this entry to confirm the cryptographic signature was recorded in the public-good log and obtain the signing certificate chain issued by Fulcio. Recording this URI enables offline and third-party verification without requiring direct access to the original signing key." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path slsa:sigstoreLogEntry ] ;
    sh:targetClass slsa:BuildEnvironmentAttestation .

slsa:BuildPlatform a sh:NodeShape ;
    rdfs:comment "The infrastructure (software, hardware, people, and organizations) used to transform source code into package artifacts. Responsible for provenance generation and isolation between tenant builds. Often a hosted, multi-tenant build service." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "True if this is a hosted (multi-tenant) platform running on shared or dedicated infrastructure, rather than an individual's workstation. Required for SLSA Build L2+." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path slsa:isHosted ],
        [ sh:datatype xsd:string ;
            sh:description "A URI uniquely identifying an entity (build platform, verifier, build image, or source repository). The primary trust anchor for consumers." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path slsa:id ],
        [ sh:description "The SLSA Build Level this platform is capable of producing, as determined by its provenance generation and isolation guarantees." ;
            sh:in ( "SLSA_BUILD_LEVEL_0" "SLSA_BUILD_LEVEL_1" "SLSA_BUILD_LEVEL_2" "SLSA_BUILD_LEVEL_3" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path slsa:buildLevel ] ;
    sh:targetClass slsa:BuildPlatform .

slsa:Consumer a sh:NodeShape ;
    rdfs:comment "A party who uses software provided by a producer. May verify provenance directly or delegate that responsibility to a separate verifier." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass slsa:Consumer .

slsa:ControlPlane a sh:NodeShape ;
    rdfs:comment "The build platform component that orchestrates each independent build execution and generates provenance. Managed by an admin and trusted to be outside of tenant control. Responsible for generating and signing provenance at SLSA Build L2+." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass slsa:ControlPlane .

slsa:DependencyInventory a sh:NodeShape ;
    rdfs:comment "A comprehensive inventory of all third-party build dependencies for an artifact, capturing direct and transitive dependencies. Supports vulnerability management and incident response." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class slsa:ResourceDescriptor ;
            sh:description "All third-party build dependencies (direct and transitive) for an artifact version, identified by URI and digest." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path slsa:dependencies ],
        [ sh:class slsa:ResourceDescriptor ;
            sh:description "A specific immutable package artifact or the artifact whose dependency inventory is recorded." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path slsa:artifact ],
        [ sh:description "The SLSA Dependency Level that this inventory and associated triage process supports." ;
            sh:in ( "SLSA_DEPENDENCY_LEVEL_0" "SLSA_DEPENDENCY_LEVEL_1" "SLSA_DEPENDENCY_LEVEL_2" "SLSA_DEPENDENCY_LEVEL_3" "SLSA_DEPENDENCY_LEVEL_4" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path slsa:dependencyLevel ] ;
    sh:targetClass slsa:DependencyInventory .

slsa:InfrastructureProvider a sh:NodeShape ;
    rdfs:comment "A party who provides software or services to other roles in the supply chain, such as a package registry maintainer or build platform operator." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass slsa:InfrastructureProvider .

slsa:Package a sh:NodeShape ;
    rdfs:comment "An identifiable unit of software intended for distribution. In the SLSA model, a package is always the output of a build process (which may be a no-op). The package name is the primary security boundary within a package ecosystem." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class slsa:ResourceDescriptor ;
            sh:description "A specific immutable package artifact or the artifact whose dependency inventory is recorded." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path slsa:artifact ],
        [ sh:datatype xsd:string ;
            sh:description "URI of the package registry where a package is published and from which consumers resolve the package name to an artifact." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path slsa:registry ],
        [ sh:datatype xsd:string ;
            sh:description "A local name for a resource within the context of an attestation, or the name of a package, producer, or party." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path slsa:name ],
        [ sh:datatype xsd:string ;
            sh:description "The package ecosystem (e.g., \"PyPA\", \"npm\", \"OCI\", \"cargo\") governing distribution conventions for this package." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path slsa:ecosystem ] ;
    sh:targetClass slsa:Package .

slsa:Producer a sh:NodeShape ;
    rdfs:comment "A party who creates software and provides it to others. Responsible for choosing an appropriate build platform, following a consistent build process, and distributing provenance to consumers." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "URI of the build platform chosen to produce artifacts." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path slsa:buildPlatformId ],
        [ sh:datatype xsd:string ;
            sh:description "A local name for a resource within the context of an attestation, or the name of a package, producer, or party." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path slsa:name ] ;
    sh:targetClass slsa:Producer .

slsa:SlsaDocument a sh:NodeShape ;
    rdfs:comment "Root wrapper for any SLSA attestation payload. Acts as the entry point for schema validation and tools." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class slsa:AdoptionMetadata ;
            sh:description "Optional structured metadata recording the SLSA adoption challenges and mitigation strategies relevant to this attestation context. Derived from empirical analysis of SLSA-related GitHub issues (Tamanna et al., 2024, arXiv:2409.05014). Intended for use by framework authors, practitioners, and tooling that tracks adoption progress alongside attestation payloads." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path slsa:adoptionMetadata ],
        [ sh:description "Whether the artifact passed or failed policy verification." ;
            sh:in ( "PASSED" "FAILED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path slsa:verificationResult ],
        [ sh:class slsa:RunDetails ;
            sh:description "Details specific to this particular execution of the build, including builder identity and metadata. REQUIRED at SLSA Build L1." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path slsa:runDetails ],
        [ sh:description "The highest verified SLSA level for each applicable track (not including transitive dependencies). At most one level per track. Implies all levels below it within the same track." ;
            sh:in ( "SLSA_BUILD_LEVEL_0" "SLSA_BUILD_LEVEL_1" "SLSA_BUILD_LEVEL_2" "SLSA_BUILD_LEVEL_3" "SLSA_SOURCE_LEVEL_1" "SLSA_SOURCE_LEVEL_2" "SLSA_SOURCE_LEVEL_3" "SLSA_SOURCE_LEVEL_4" ) ;
            sh:minCount 1 ;
            sh:order 4 ;
            sh:path slsa:verifiedLevels ],
        [ sh:class slsa:Verifier ;
            sh:description "Identifies the entity that performed the verification." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path slsa:verifier ],
        [ sh:class slsa:BuildDefinition ;
            sh:description "All inputs to the build, sufficient to initialise and reproduce it. REQUIRED at SLSA Build L1." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path slsa:buildDefinition ] ;
    sh:targetClass slsa:SlsaDocument .

slsa:SourceProvenanceAttestation a sh:NodeShape ;
    rdfs:comment "An attestation describing how a source revision came to exist: where it was hosted, when it was generated, what process was used, who the contributors were, and which technical controls were enforced by the Source Control System." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "URI of the Rekor transparency log entry recording this attestation or artifact signature (e.g., \"https://rekor.sigstore.dev/api/v1/log/entries/24296fb...\"). The Rekor log provides an immutable, auditable record of signing events that underpins Sigstore keyless signing. Verifiers can fetch this entry to confirm the cryptographic signature was recorded in the public-good log and obtain the signing certificate chain issued by Fulcio. Recording this URI enables offline and third-party verification without requiring direct access to the original signing key." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path slsa:sigstoreLogEntry ],
        [ sh:description "The SLSA Source Level achieved or verified for a source repository or revision." ;
            sh:in ( "SLSA_SOURCE_LEVEL_1" "SLSA_SOURCE_LEVEL_2" "SLSA_SOURCE_LEVEL_3" "SLSA_SOURCE_LEVEL_4" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path slsa:sourceLevel ],
        [ sh:datatype xsd:string ;
            sh:description "The attestation payload — an arbitrary JSON object whose schema is fully determined by predicateType." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path slsa:predicate ],
        [ sh:datatype xsd:string ;
            sh:description "URI or name of the tool used to cryptographically sign the artifact or attestation (e.g., \"https://github.com/sigstore/cosign\", \"https://github.com/notaryproject/notation\"). In the SSF reference architecture the Signing Service layer is distinct from the Build Service; recording the signing tool enables verifiers to select the matching verification workflow. For Sigstore keyless signing the value should be the Cosign release URI." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path slsa:signingTool ],
        [ sh:datatype xsd:string ;
            sh:description "URI indicating where this signed attestation is publicly stored or retrievable. No universal standard for attestation storage location was established in SLSA v1.0; Sigstore and VCS-embedded storage are two common approaches. Explicitly recording this URI addresses the storage ambiguity identified as a significant adoption barrier: practitioners reported uncertainty about where generated attestations should be stored (Tamanna et al., 2024, LF.1)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path slsa:attestationStorageUri ],
        [ sh:class slsa:SourceRevision ;
            sh:description "The source revision that this attestation describes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path slsa:revision ],
        [ sh:class slsa:ResourceDescriptor ;
            sh:description "The set of software artifacts to which a predicate applies. Each entry MUST contain a digest." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path slsa:subject ],
        [ sh:datatype xsd:string ;
            sh:description "Technical controls actively enforced by the Source Control System when this revision was created (e.g., \"two-party review\", \"branch protection\", \"status checks\")." ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path slsa:controlsEnforced ],
        [ sh:datatype xsd:string ;
            sh:description "URI identifying the schema and semantics of the predicate field. Used to distinguish different attestation types (e.g., SLSA Provenance vs. Verification Summary Attestation)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path slsa:predicateType ],
        [ sh:datatype xsd:string ;
            sh:description "Always \"https://in-toto.io/Statement/v1\". Identifies the in-toto statement schema version and namespace." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path slsa:_type ] ;
    sh:targetClass slsa:SourceProvenanceAttestation .

slsa:Statement a sh:NodeShape ;
    rdfs:comment "The middle layer of an in-toto software attestation (Statement v1). Binds an authenticated predicate to one or more subject artifacts, allowing predicate-agnostic processing and storage." ;
    sh:closed false ;
    sh:ignoredProperties ( slsa:buildDefinition slsa:verifier slsa:buildImage slsa:resourceUri rdf:type slsa:dependencyLevels slsa:slsaVersion slsa:runDetails slsa:controlsEnforced slsa:verificationResult slsa:measurements slsa:buildId slsa:inputAttestations slsa:revision slsa:sourceLevel slsa:buildEnvLevel slsa:verifiedLevels slsa:timeVerified slsa:policy ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "URI indicating where this signed attestation is publicly stored or retrievable. No universal standard for attestation storage location was established in SLSA v1.0; Sigstore and VCS-embedded storage are two common approaches. Explicitly recording this URI addresses the storage ambiguity identified as a significant adoption barrier: practitioners reported uncertainty about where generated attestations should be stored (Tamanna et al., 2024, LF.1)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path slsa:attestationStorageUri ],
        [ sh:datatype xsd:string ;
            sh:description "URI of the Rekor transparency log entry recording this attestation or artifact signature (e.g., \"https://rekor.sigstore.dev/api/v1/log/entries/24296fb...\"). The Rekor log provides an immutable, auditable record of signing events that underpins Sigstore keyless signing. Verifiers can fetch this entry to confirm the cryptographic signature was recorded in the public-good log and obtain the signing certificate chain issued by Fulcio. Recording this URI enables offline and third-party verification without requiring direct access to the original signing key." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path slsa:sigstoreLogEntry ],
        [ sh:datatype xsd:string ;
            sh:description "Always \"https://in-toto.io/Statement/v1\". Identifies the in-toto statement schema version and namespace." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path slsa:_type ],
        [ sh:datatype xsd:string ;
            sh:description "The attestation payload — an arbitrary JSON object whose schema is fully determined by predicateType." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path slsa:predicate ],
        [ sh:datatype xsd:string ;
            sh:description "URI identifying the schema and semantics of the predicate field. Used to distinguish different attestation types (e.g., SLSA Provenance vs. Verification Summary Attestation)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path slsa:predicateType ],
        [ sh:datatype xsd:string ;
            sh:description "URI or name of the tool used to cryptographically sign the artifact or attestation (e.g., \"https://github.com/sigstore/cosign\", \"https://github.com/notaryproject/notation\"). In the SSF reference architecture the Signing Service layer is distinct from the Build Service; recording the signing tool enables verifiers to select the matching verification workflow. For Sigstore keyless signing the value should be the Cosign release URI." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path slsa:signingTool ],
        [ sh:class slsa:ResourceDescriptor ;
            sh:description "The set of software artifacts to which a predicate applies. Each entry MUST contain a digest." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path slsa:subject ] ;
    sh:targetClass slsa:Statement .

slsa:VerificationSummaryAttestation a sh:NodeShape ;
    rdfs:comment "An attestation predicate (predicateType \"https://slsa.dev/verification_summary/v1\") issued by a trusted verifier stating that one or more artifacts were evaluated against a policy and the SLSA level at which they were verified. Allows consumers to trust the verifier's determination without needing access to all underlying provenance." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The highest verified SLSA level for each applicable track (not including transitive dependencies). At most one level per track. Implies all levels below it within the same track." ;
            sh:in ( "SLSA_BUILD_LEVEL_0" "SLSA_BUILD_LEVEL_1" "SLSA_BUILD_LEVEL_2" "SLSA_BUILD_LEVEL_3" "SLSA_SOURCE_LEVEL_1" "SLSA_SOURCE_LEVEL_2" "SLSA_SOURCE_LEVEL_3" "SLSA_SOURCE_LEVEL_4" ) ;
            sh:minCount 1 ;
            sh:order 6 ;
            sh:path slsa:verifiedLevels ],
        [ sh:datatype xsd:string ;
            sh:description "The attestation payload — an arbitrary JSON object whose schema is fully determined by predicateType." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path slsa:predicate ],
        [ sh:datatype xsd:string ;
            sh:description "Map from SlsaResult to count of transitive dependencies verified at that level (JSON object string). Allows policy engines to enforce minimum levels on the full dependency graph." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path slsa:dependencyLevels ],
        [ sh:class slsa:ResourceDescriptor ;
            sh:description "All attestations consulted during verification. If non-empty, MUST be complete — it MUST list every attestation used. Each entry MUST contain a digest; SHOULD contain a URI." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path slsa:inputAttestations ],
        [ sh:class slsa:Verifier ;
            sh:description "Identifies the entity that performed the verification." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path slsa:verifier ],
        [ sh:datatype xsd:string ;
            sh:description "Always \"https://in-toto.io/Statement/v1\". Identifies the in-toto statement schema version and namespace." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path slsa:_type ],
        [ sh:datatype xsd:string ;
            sh:description "URI indicating where this signed attestation is publicly stored or retrievable. No universal standard for attestation storage location was established in SLSA v1.0; Sigstore and VCS-embedded storage are two common approaches. Explicitly recording this URI addresses the storage ambiguity identified as a significant adoption barrier: practitioners reported uncertainty about where generated attestations should be stored (Tamanna et al., 2024, LF.1)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path slsa:attestationStorageUri ],
        [ sh:datatype xsd:string ;
            sh:description "URI identifying the resource associated with the artifact being verified. SHOULD be the URI from which the consumer fetches the artifact." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path slsa:resourceUri ],
        [ sh:class slsa:ResourceDescriptor ;
            sh:description "The set of software artifacts to which a predicate applies. Each entry MUST contain a digest." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path slsa:subject ],
        [ sh:datatype xsd:string ;
            sh:description "URI or name of the tool used to cryptographically sign the artifact or attestation (e.g., \"https://github.com/sigstore/cosign\", \"https://github.com/notaryproject/notation\"). In the SSF reference architecture the Signing Service layer is distinct from the Build Service; recording the signing tool enables verifiers to select the matching verification workflow. For Sigstore keyless signing the value should be the Cosign release URI." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path slsa:signingTool ],
        [ sh:description "Whether the artifact passed or failed policy verification." ;
            sh:in ( "PASSED" "FAILED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path slsa:verificationResult ],
        [ sh:datatype xsd:string ;
            sh:description "Timestamp (RFC 3339) indicating when the verification occurred." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path slsa:timeVerified ],
        [ sh:datatype xsd:string ;
            sh:description "URI identifying the schema and semantics of the predicate field. Used to distinguish different attestation types (e.g., SLSA Provenance vs. Verification Summary Attestation)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path slsa:predicateType ],
        [ sh:datatype xsd:string ;
            sh:description "URI of the Rekor transparency log entry recording this attestation or artifact signature (e.g., \"https://rekor.sigstore.dev/api/v1/log/entries/24296fb...\"). The Rekor log provides an immutable, auditable record of signing events that underpins Sigstore keyless signing. Verifiers can fetch this entry to confirm the cryptographic signature was recorded in the public-good log and obtain the signing certificate chain issued by Fulcio. Recording this URI enables offline and third-party verification without requiring direct access to the original signing key." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path slsa:sigstoreLogEntry ],
        [ sh:class slsa:ResourceDescriptor ;
            sh:description "The policy the subject was verified against. MUST contain a URI; SHOULD contain a digest identifying the exact policy version." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path slsa:policy ],
        [ sh:datatype xsd:string ;
            sh:description "Version of the SLSA specification used during verification, in MAJOR.MINOR format (e.g., \"1.0\")." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path slsa:slsaVersion ] ;
    sh:targetClass slsa:VerificationSummaryAttestation .

slsa:AdoptionMetadata a sh:NodeShape ;
    rdfs:comment "Optional structured metadata capturing the SLSA adoption challenges and mitigation strategies relevant to a given attestation or deployment context. Derived from empirical analysis of 1,523 SLSA-related GitHub issues across 233 repositories (Tamanna et al., 2024, arXiv:2409.05014). Use this class to document which challenge themes apply to the current deployment and which strategies are being employed or recommended. Attach via the adoptionMetadata slot on SlsaDocument." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The mitigation strategies being employed or recommended in this attestation or deployment context, drawn from the empirically identified strategy taxonomy (Tamanna et al., 2024, arXiv:2409.05014)." ;
            sh:in ( "ENHANCE_ALIGNMENT_FLEXIBILITY" "PROVIDE_DETAILED_DOCUMENTATION" "STREAMLINE_PROVENANCE_GENERATION" "IMPROVE_VERIFICATION_PROCESS" "COLLABORATE_WITH_COMMUNITY" ) ;
            sh:order 1 ;
            sh:path slsa:strategies ],
        [ sh:description "The adoption challenge themes that apply to this attestation or deployment context, drawn from the empirically identified challenge taxonomy (Tamanna et al., 2024, arXiv:2409.05014)." ;
            sh:in ( "COMPLEX_IMPLEMENTATION" "UNCLEAR_COMMUNICATION" "LIMITED_FEASIBILITY" "UNCLEAR_RELEVANCE" ) ;
            sh:order 0 ;
            sh:path slsa:challenges ] ;
    sh:targetClass slsa:AdoptionMetadata .

slsa:BuildImage a sh:NodeShape ;
    rdfs:comment "The template for a build environment, such as a VM or container image. Comprises the root filesystem, pre-installed guest OS and packages, the build executor, and the build agent. Created by a build image producer and consumed by the hosted build platform." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class slsa:BuildProvenance ;
            sh:description "SLSA Build Provenance for a build image, describing how the image itself was produced. Required for SLSA Build Environment L1+." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path slsa:provenance ],
        [ sh:description "The SLSA Build Environment Level supported or represented, reflecting the strength of the integrity guarantees provided." ;
            sh:in ( "SLSA_BUILD_ENV_LEVEL_0" "SLSA_BUILD_ENV_LEVEL_1" "SLSA_BUILD_ENV_LEVEL_2" "SLSA_BUILD_ENV_LEVEL_3" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path slsa:buildEnvLevel ],
        [ sh:datatype xsd:string ;
            sh:description "URI uniquely identifying this build image version (e.g., an OCI image reference with digest)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path slsa:id ] ;
    sh:targetClass slsa:BuildImage .

slsa:BuildMetadata a sh:NodeShape ;
    rdfs:comment "Metadata about a specific invocation of the build, including timing information and a unique build identifier for log correlation." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A globally unique identifier for a build invocation, useful for finding associated logs. Format defined by builder.id; treated as opaque and case-sensitive. The value SHOULD be globally unique." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path slsa:invocationId ],
        [ sh:datatype xsd:string ;
            sh:description "Timestamp (RFC 3339) of when the build started." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path slsa:startedOn ],
        [ sh:datatype xsd:string ;
            sh:description "Timestamp (RFC 3339) of when the build completed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path slsa:finishedOn ] ;
    sh:targetClass slsa:BuildMetadata .

slsa:BuildProvenance a sh:NodeShape ;
    rdfs:comment "An attestation predicate (predicateType \"https://slsa.dev/provenance/v1\") that describes how a set of output artifacts was produced by a build platform. Consumers use this to verify artifact authenticity and trace artifacts back through the supply chain." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The attestation payload — an arbitrary JSON object whose schema is fully determined by predicateType." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path slsa:predicate ],
        [ sh:datatype xsd:string ;
            sh:description "URI indicating where this signed attestation is publicly stored or retrievable. No universal standard for attestation storage location was established in SLSA v1.0; Sigstore and VCS-embedded storage are two common approaches. Explicitly recording this URI addresses the storage ambiguity identified as a significant adoption barrier: practitioners reported uncertainty about where generated attestations should be stored (Tamanna et al., 2024, LF.1)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path slsa:attestationStorageUri ],
        [ sh:datatype xsd:string ;
            sh:description "URI identifying the schema and semantics of the predicate field. Used to distinguish different attestation types (e.g., SLSA Provenance vs. Verification Summary Attestation)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path slsa:predicateType ],
        [ sh:datatype xsd:string ;
            sh:description "URI or name of the tool used to cryptographically sign the artifact or attestation (e.g., \"https://github.com/sigstore/cosign\", \"https://github.com/notaryproject/notation\"). In the SSF reference architecture the Signing Service layer is distinct from the Build Service; recording the signing tool enables verifiers to select the matching verification workflow. For Sigstore keyless signing the value should be the Cosign release URI." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path slsa:signingTool ],
        [ sh:datatype xsd:string ;
            sh:description "Always \"https://in-toto.io/Statement/v1\". Identifies the in-toto statement schema version and namespace." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path slsa:_type ],
        [ sh:datatype xsd:string ;
            sh:description "URI of the Rekor transparency log entry recording this attestation or artifact signature (e.g., \"https://rekor.sigstore.dev/api/v1/log/entries/24296fb...\"). The Rekor log provides an immutable, auditable record of signing events that underpins Sigstore keyless signing. Verifiers can fetch this entry to confirm the cryptographic signature was recorded in the public-good log and obtain the signing certificate chain issued by Fulcio. Recording this URI enables offline and third-party verification without requiring direct access to the original signing key." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path slsa:sigstoreLogEntry ],
        [ sh:class slsa:BuildDefinition ;
            sh:description "All inputs to the build, sufficient to initialise and reproduce it. REQUIRED at SLSA Build L1." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path slsa:buildDefinition ],
        [ sh:class slsa:RunDetails ;
            sh:description "Details specific to this particular execution of the build, including builder identity and metadata. REQUIRED at SLSA Build L1." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path slsa:runDetails ],
        [ sh:class slsa:ResourceDescriptor ;
            sh:description "The set of software artifacts to which a predicate applies. Each entry MUST contain a digest." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path slsa:subject ] ;
    sh:targetClass slsa:BuildProvenance .

slsa:Builder a sh:NodeShape ;
    rdfs:comment "Represents the transitive closure of all software, hardware, and entities trusted to faithfully execute the build and record provenance. The builder.id is the primary basis for determining SLSA Build Level." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class slsa:ResourceDescriptor ;
            sh:description "Dependencies used by the control plane orchestrator that are not run within the build workload but may affect provenance generation or security guarantees." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path slsa:builderDependencies ],
        [ sh:datatype xsd:string ;
            sh:description "A URI uniquely identifying an entity (build platform, verifier, build image, or source repository). The primary trust anchor for consumers." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path slsa:id ],
        [ sh:datatype xsd:string ;
            sh:description "A semantic version tag (e.g., \"v1.2.3\") assigned to the builder or the produced artifact at the time of the build. Practitioners recommended implementing versioning tagging early in SLSA framework deployment to facilitate progress tracking, reduce maintenance confusion from breaking changes, and enable more straightforward verification (Tamanna et al., 2024, S4.2)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path slsa:versionTag ],
        [ sh:datatype xsd:string ;
            sh:description "Map of component names to their version strings, represented as a JSON object (string → string)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path slsa:version ] ;
    sh:targetClass slsa:Builder .

slsa:DigestSet a sh:NodeShape ;
    rdfs:comment "A set of cryptographic digests for an artifact, keyed by algorithm name (e.g., \"sha256\", \"gitCommit\"). Provides enough information for consumers to verify artifact integrity using their preferred algorithm." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Lowercase hex-encoded SHA-512 digest of the artifact." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path slsa:sha512 ],
        [ sh:datatype xsd:string ;
            sh:description "Git commit SHA identifying a source-backed artifact." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path slsa:gitCommit ],
        [ sh:datatype xsd:string ;
            sh:description "Lowercase hex-encoded SHA-256 digest of the artifact." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path slsa:sha256 ] ;
    sh:targetClass slsa:DigestSet .

slsa:SourceRepository a sh:NodeShape ;
    rdfs:comment "A self-contained unit that holds the content and complete revision history for a set of files, along with metadata such as branches and tags. Hosted and governed by a Source Control System." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Canonical URI that uniquely identifies this source repository." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path slsa:id ],
        [ sh:description "The SLSA Source Level achieved or verified for a source repository or revision." ;
            sh:in ( "SLSA_SOURCE_LEVEL_1" "SLSA_SOURCE_LEVEL_2" "SLSA_SOURCE_LEVEL_3" "SLSA_SOURCE_LEVEL_4" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path slsa:sourceLevel ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description of a repository's purpose or a resource." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path slsa:description ] ;
    sh:targetClass slsa:SourceRepository .

slsa:SourceRevision a sh:NodeShape ;
    rdfs:comment "A specific, logically immutable snapshot of a source repository's tracked files. Uniquely identified by a revision identifier such as a cryptographic hash (e.g., git commit SHA) or a path-qualified sequential number (e.g., SVN)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class slsa:SourceRepository ;
            sh:description "The source repository that contains this revision." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path slsa:repository ],
        [ sh:datatype xsd:string ;
            sh:description "Timestamp (RFC 3339) of when this source revision was created." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path slsa:timestamp ],
        [ sh:datatype xsd:string ;
            sh:description "Identity of the person or automation that authored this revision (e.g., an email address or platform username)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path slsa:author ],
        [ sh:datatype xsd:string ;
            sh:description "Immutable identifier for a source revision (e.g., git commit SHA, path-qualified sequential number)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path slsa:revisionId ],
        [ sh:description "The type of human or automated review process used to approve this source revision. Captures the contested forms of two-party review — including pair programming and mob programming — whose security equivalence to standard asynchronous two-party review is an open question identified in practitioner community discussions (Tamanna et al., 2024, LF.2). See ReviewTypeEnum for defined values." ;
            sh:in ( "TWO_PARTY" "PAIR_PROGRAMMING" "MOB_PROGRAMMING" "AUTOMATED" ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path slsa:reviewType ],
        [ sh:datatype xsd:string ;
            sh:description "Revision IDs of the parent revision(s), forming the directed acyclic graph of change history." ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path slsa:parentRevisions ] ;
    sh:targetClass slsa:SourceRevision .

slsa:BuildDefinition a sh:NodeShape ;
    rdfs:comment "Describes all inputs to the build in enough detail to initialise and reproduce the build. The accuracy and completeness are implied by the builder identified in runDetails." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Top-level, independent inputs under external (tenant or user) control. MUST be complete at SLSA Build L3. Stored as a JSON object. Verifiers SHOULD reject unrecognized fields." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path slsa:externalParameters ],
        [ sh:datatype xsd:string ;
            sh:description "URI or name of the CI/CD pipeline orchestration system that coordinated this build (e.g., \"https://tekton.dev\", \"https://github.com/features/actions\", \"https://jenkins.io\"). In the SSF reference architecture this is the Build Service layer that feeds the Artifact Registry. Providing this field helps distinguish the orchestrator from the provenance-generating builder identity (builder.id) in complex deployments where they differ (e.g., a Tekton Pipeline running on Google Cloud Pipelines)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path slsa:pipelineOrchestrator ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether all build inputs are fully isolated to the dependencies declared in resolvedDependencies, with no network access or filesystem references outside the explicit build graph. Hermetic builds are a stated requirement for SLSA Build L3; practitioners identified this as one of the most commonly cited implementation barriers, with over 50% of surveyed practitioners finding hermetic build requirements difficult to implement (Tamanna et al., 2024, CI.1)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path slsa:hermeticBuild ],
        [ sh:datatype xsd:string ;
            sh:description "Parameters set internally by the build platform. Intended for debugging, incident response, and enabling reproducible builds. Stored as a JSON object; need not be verified by consumers." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path slsa:internalParameters ],
        [ sh:datatype xsd:string ;
            sh:description "URI or name of the tool used to generate provenance for this build (e.g., \"https://github.com/slsa-framework/slsa-github-generator\"). Standardizing this field across builds reduces confusion, supports reproducibility verification, and aligns with the recommended strategy of simplifying and standardizing provenance generation processes (Tamanna et al., 2024, S3.1)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path slsa:provenanceGenerationTool ],
        [ sh:class slsa:ResourceDescriptor ;
            sh:description "Unordered collection of artifacts needed at build time (config files, source, build tools). Completeness is best effort through SLSA Build L3." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path slsa:resolvedDependencies ],
        [ sh:datatype xsd:string ;
            sh:description "URI identifying the template for how to perform the build and how to interpret the parameters and dependencies. SHOULD resolve to a human-readable specification. REQUIRED at SLSA Build L1." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path slsa:buildType ] ;
    sh:targetClass slsa:BuildDefinition .

slsa:RunDetails a sh:NodeShape ;
    rdfs:comment "Details specific to this particular execution of the build, including the trusted builder and optional run-level metadata." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class slsa:BuildMetadata ;
            sh:description "Metadata about this particular build execution." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path slsa:buildMetadata ],
        [ sh:class slsa:ResourceDescriptor ;
            sh:description "Additional artifacts produced during the build that are NOT the primary output but may be useful for debugging or incident response (e.g., build logs, intermediate artifacts)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path slsa:byproducts ],
        [ sh:class slsa:Builder ;
            sh:description "Identifies the build platform that executed the build and is trusted to have correctly generated this provenance. REQUIRED at SLSA Build L1." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path slsa:builder ] ;
    sh:targetClass slsa:RunDetails .

slsa:Verifier a sh:NodeShape ;
    rdfs:comment "The entity that performed verification of an artifact and issued a Verification Summary Attestation. Consumers MUST accept only specific (signer, verifier) pairs." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Map of component names to their version strings, represented as a JSON object (string → string)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path slsa:version ],
        [ sh:datatype xsd:string ;
            sh:description "A URI uniquely identifying an entity (build platform, verifier, build image, or source repository). The primary trust anchor for consumers." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path slsa:id ] ;
    sh:targetClass slsa:Verifier .

slsa:ResourceDescriptor a sh:NodeShape ;
    rdfs:comment "A reference to a software artifact including its location, digest, and optional metadata. Used throughout SLSA to describe inputs, outputs, and dependencies in provenance attestations." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A URI uniquely identifying a resource, such as a package URL (purl), git repository URL, or OCI image reference." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path slsa:uri ],
        [ sh:datatype xsd:string ;
            sh:description "URI from which a resource can be downloaded, if different from its identifying URI." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path slsa:downloadLocation ],
        [ sh:datatype xsd:string ;
            sh:description "IANA media type of a resource's content (e.g., \"application/octet-stream\", \"application/vnd.oci.image.manifest.v1+json\")." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path slsa:mediaType ],
        [ sh:datatype xsd:string ;
            sh:description "A local name for a resource within the context of an attestation, or the name of a package, producer, or party." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path slsa:name ],
        [ sh:datatype xsd:string ;
            sh:description "Arbitrary vendor-specific key-value annotations." ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path slsa:annotations ],
        [ sh:class slsa:DigestSet ;
            sh:description "Set of cryptographic digests of a resource's content used for integrity verification." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path slsa:digest ] ;
    sh:targetClass slsa:ResourceDescriptor .

