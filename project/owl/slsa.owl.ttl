@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix linkml: <https://w3id.org/linkml/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pav: <http://purl.org/pav/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix slsa: <https://w3id.org/lmodel/slsa/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/lmodel/slsa.owl.ttl> a owl:Ontology ;
    rdfs:label "slsa" ;
    dcterms:license "Apache-2.0" ;
    dcterms:source <https://slsa.dev/spec/v1.0> ;
    dcterms:title "slsa" ;
    pav:version "1.0.0" ;
    rdfs:seeAlso <https://arxiv.org/abs/2409.05014>,
        <https://lmodel.github.io/slsa>,
        <https://openssf.org/technical-initiatives/software-supply-chain/>,
        <https://slsa.dev/spec/v1.2/> ;
    skos:definition "Electronic (LinkML) Version of Supply-chain Levels for Software Artifacts (SLSA)" .

slsa:BuildEnvironmentAttestation a owl:Class ;
    rdfs:label "BuildEnvironmentAttestation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom slsa:BuildImage ;
            owl:onProperty slsa:buildImage ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:measurements ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slsa:buildId ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:BuildEnvLevelEnum ;
            owl:onProperty slsa:buildEnvLevel ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:buildImage ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:measurements ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:buildEnvLevel ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:buildEnvLevel ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:buildId ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:buildId ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:buildImage ],
        slsa:Statement ;
    skos:definition "An attestation describing the integrity of a build environment at the time a specific build was dispatched and executed. Used to verify that a build ran in the expected, untampered environment." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:BuildPlatform a owl:Class ;
    rdfs:label "BuildPlatform" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:isHosted ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:isHosted ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:BuildLevelEnum ;
            owl:onProperty slsa:buildLevel ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:buildLevel ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:buildLevel ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty slsa:isHosted ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slsa:id ] ;
    skos:definition "The infrastructure (software, hardware, people, and organizations) used to transform source code into package artifacts. Responsible for provenance generation and isolation between tenant builds. Often a hosted, multi-tenant build service." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:Consumer a owl:Class ;
    rdfs:label "Consumer" ;
    skos:definition "A party who uses software provided by a producer. May verify provenance directly or delegate that responsibility to a separate verifier." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:ControlPlane a owl:Class ;
    rdfs:label "ControlPlane" ;
    skos:definition "The build platform component that orchestrates each independent build execution and generates provenance. Managed by an admin and trusted to be outside of tenant control. Responsible for generating and signing provenance at SLSA Build L2+." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:DependencyInventory a owl:Class ;
    rdfs:label "DependencyInventory" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:dependencyLevel ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:artifact ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:ResourceDescriptor ;
            owl:onProperty slsa:dependencies ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:artifact ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:ResourceDescriptor ;
            owl:onProperty slsa:artifact ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:dependencies ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:dependencyLevel ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:DependencyLevelEnum ;
            owl:onProperty slsa:dependencyLevel ] ;
    skos:definition "A comprehensive inventory of all third-party build dependencies for an artifact, capturing direct and transitive dependencies. Supports vulnerability management and incident response." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:InfrastructureProvider a owl:Class ;
    rdfs:label "InfrastructureProvider" ;
    skos:definition "A party who provides software or services to other roles in the supply chain, such as a package registry maintainer or build platform operator." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:Package a owl:Class ;
    rdfs:label "Package" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:registry ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:artifact ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:registry ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:registry ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:ResourceDescriptor ;
            owl:onProperty slsa:artifact ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:ecosystem ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:ecosystem ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:artifact ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:ecosystem ] ;
    skos:definition "An identifiable unit of software intended for distribution. In the SLSA model, a package is always the output of a build process (which may be a no-op). The package name is the primary security boundary within a package ecosystem." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:Producer a owl:Class ;
    rdfs:label "Producer" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:buildPlatformId ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:buildPlatformId ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:buildPlatformId ] ;
    skos:definition "A party who creates software and provides it to others. Responsible for choosing an appropriate build platform, following a consistent build process, and distributing provenance to consumers." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:SlsaDocument a owl:Class ;
    rdfs:label "SlsaDocument" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom slsa:Verifier ;
            owl:onProperty slsa:verifier ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slsa:buildDefinition ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slsa:verificationResult ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:adoptionMetadata ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:verifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:RunDetails ;
            owl:onProperty slsa:runDetails ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:buildDefinition ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:BuildDefinition ;
            owl:onProperty slsa:buildDefinition ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:SlsaResultEnum ;
            owl:onProperty slsa:verifiedLevels ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slsa:verifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:AdoptionMetadata ;
            owl:onProperty slsa:adoptionMetadata ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slsa:verifiedLevels ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:runDetails ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slsa:runDetails ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:VerificationResultEnum ;
            owl:onProperty slsa:verificationResult ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:verificationResult ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:adoptionMetadata ] ;
    skos:definition "Root wrapper for any SLSA attestation payload. Acts as the entry point for schema validation and tools." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:SourceProvenanceAttestation a owl:Class ;
    rdfs:label "SourceProvenanceAttestation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:revision ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:revision ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:controlsEnforced ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:SourceRevision ;
            owl:onProperty slsa:revision ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:controlsEnforced ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:sourceLevel ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:sourceLevel ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:SourceLevelEnum ;
            owl:onProperty slsa:sourceLevel ],
        slsa:Statement ;
    skos:definition "An attestation describing how a source revision came to exist: where it was hosted, when it was generated, what process was used, who the contributors were, and which technical controls were enforced by the Source Control System." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:VerificationSummaryAttestation a owl:Class ;
    rdfs:label "VerificationSummaryAttestation" ;
    rdfs:seeAlso <https://openssf.org/projects/guac/> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:timeVerified ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slsa:verifiedLevels ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slsa:resourceUri ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:verificationResult ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slsa:policy ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slsa:verifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:dependencyLevels ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slsa:verificationResult ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:ResourceDescriptor ;
            owl:onProperty slsa:inputAttestations ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:inputAttestations ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:slsaVersion ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:SlsaResultEnum ;
            owl:onProperty slsa:verifiedLevels ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:VerificationResultEnum ;
            owl:onProperty slsa:verificationResult ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:timeVerified ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:verifier ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:resourceUri ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:dependencyLevels ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:policy ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:dependencyLevels ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:Verifier ;
            owl:onProperty slsa:verifier ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:slsaVersion ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:slsaVersion ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:resourceUri ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:timeVerified ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:ResourceDescriptor ;
            owl:onProperty slsa:policy ],
        slsa:Statement ;
    skos:definition "An attestation predicate (predicateType \"https://slsa.dev/verification_summary/v1\") issued by a trusted verifier stating that one or more artifacts were evaluated against a policy and the SLSA level at which they were verified. Allows consumers to trust the verifier's determination without needing access to all underlying provenance." ;
    skos:editorialNote "Verification complexity (Tamanna et al., 2024, LF.1): The slsa-verifier tool was highlighted by practitioners for complexity and redundancy. No standardized attestation storage model existed as of SLSA v1.0; inconsistencies between package manager registries and stored files can undermine verification accuracy. Downstream systems also lack clear guidance on how to consume and communicate attestation data to other stakeholders." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:guacUri a owl:DatatypeProperty ;
    rdfs:label "guacUri" ;
    skos:definition "URI to query the GUAC (Graph for Understanding Artifact Composition) instance for dependency and provenance graph data related to this artifact (e.g., \"https://guac.example.com/api/v0/artifact/sha256:...\"). GUAC is an OpenSSF project that ingests SLSA provenance, SBOMs, and vulnerability data to produce a queryable supply chain graph. Providing this URI enables consumers to retrieve the full transitive dependency graph and associated risk signals without reprocessing all upstream attestations." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:securityInsightsUri a owl:DatatypeProperty ;
    rdfs:label "securityInsightsUri" ;
    skos:definition "URI to the SECURITY-INSIGHTS.yml file for the project that produced this artifact (e.g., \"https://raw.githubusercontent.com/example/myapp/main/ SECURITY-INSIGHTS.yml\"). Security Insights is an OpenSSF project that defines a machine-processable format for projects to self-report their security practices, vulnerability disclosure policy, and tool usage. Together with SLSA provenance it forms a complementary view: provenance describes a specific artifact's build; Security Insights describes the project's ongoing security posture." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

<https://w3id.org/lmodel/slsa/AdoptionChallengeEnum#COMPLEX_IMPLEMENTATION> a owl:Class ;
    rdfs:label "COMPLEX_IMPLEMENTATION" ;
    rdfs:subClassOf slsa:AdoptionChallengeEnum ;
    skos:definition "(CI — 901 issues) Challenges integrating SLSA into projects: complicated provenance generation including blocking pre-submit jobs, lack of non-build configuration support, and sensitive-data handling risks (CI.1); and intricate ongoing maintenance of required tools including incompatibilities, silent failures, and documentation drift (CI.2)." .

<https://w3id.org/lmodel/slsa/AdoptionChallengeEnum#LIMITED_FEASIBILITY> a owl:Class ;
    rdfs:label "LIMITED_FEASIBILITY" ;
    rdfs:subClassOf slsa:AdoptionChallengeEnum ;
    skos:definition "(LF — 219 issues) Challenges with practical feasibility of SLSA requirements: complexity and lack of standardization in attestation verification tooling, no standardized storage model for attestations, and security concerns about verification accuracy (LF.1); and difficulty implementing two-party review for single-maintainer open-source projects (LF.2)." .

<https://w3id.org/lmodel/slsa/AdoptionChallengeEnum#UNCLEAR_COMMUNICATION> a owl:Class ;
    rdfs:label "UNCLEAR_COMMUNICATION" ;
    rdfs:subClassOf slsa:AdoptionChallengeEnum ;
    skos:definition "(UC — 357 issues) Challenges understanding SLSA documentation: unclear definitions of key terms such as \"provenance\", \"attestation\", \"hermetic\", \"hosted\", and \"non-falsifiable\" (UC.1); and lack of clear, ecosystem-specific guidance on how to apply SLSA requirements in practice (UC.2)." .

<https://w3id.org/lmodel/slsa/AdoptionChallengeEnum#UNCLEAR_RELEVANCE> a owl:Class ;
    rdfs:label "UNCLEAR_RELEVANCE" ;
    rdfs:subClassOf slsa:AdoptionChallengeEnum ;
    skos:definition "(UR — 46 issues) Challenges understanding SLSA's relevance and distinct value: confusion about which attacks SLSA mitigates, how it differs from OpenSSF best practices, and ecosystem-level policy inconsistencies (e.g., npm package naming divergence) that undermine attestation accuracy (UR.1)." .

slsa:AdoptionMetadata a owl:Class ;
    rdfs:label "AdoptionMetadata" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom slsa:AdoptionChallengeEnum ;
            owl:onProperty slsa:challenges ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:AdoptionStrategyEnum ;
            owl:onProperty slsa:strategies ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:strategies ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:challenges ] ;
    skos:definition "Optional structured metadata capturing the SLSA adoption challenges and mitigation strategies relevant to a given attestation or deployment context. Derived from empirical analysis of 1,523 SLSA-related GitHub issues across 233 repositories (Tamanna et al., 2024, arXiv:2409.05014). Use this class to document which challenge themes apply to the current deployment and which strategies are being employed or recommended. Attach via the adoptionMetadata slot on SlsaDocument." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

<https://w3id.org/lmodel/slsa/AdoptionStrategyEnum#COLLABORATE_WITH_COMMUNITY> a owl:Class ;
    rdfs:label "COLLABORATE_WITH_COMMUNITY" ;
    rdfs:subClassOf slsa:AdoptionStrategyEnum ;
    skos:definition "(S5) Collaborate with the community: foster engagement by aligning SLSA verification with industry standards and providing guidance for novice users (S5.1); promote learning and knowledge-sharing, including cross-project collaboration for single-maintainer projects (S5.2)." .

<https://w3id.org/lmodel/slsa/AdoptionStrategyEnum#ENHANCE_ALIGNMENT_FLEXIBILITY> a owl:Class ;
    rdfs:label "ENHANCE_ALIGNMENT_FLEXIBILITY" ;
    rdfs:subClassOf slsa:AdoptionStrategyEnum ;
    skos:definition "(S1) Enhance SLSA alignment and flexibility: incorporate build-system tracks for more tailored approaches (S1.1); gamify adoption levels so producers aim for higher levels (S1.2); ensure flexibility for diverse organizational and ecosystem needs (S1.3); align SLSA with OpenSSF best practices including SECURITY.md and silver/gold criteria (S1.4)." .

<https://w3id.org/lmodel/slsa/AdoptionStrategyEnum#IMPROVE_VERIFICATION_PROCESS> a owl:Class ;
    rdfs:label "IMPROVE_VERIFICATION_PROCESS" ;
    rdfs:subClassOf slsa:AdoptionStrategyEnum ;
    skos:definition "(S4) Improve the SLSA verification process: strengthen verification with better security guarantees and level-determination algorithms (S4.1); implement versioning tagging early to facilitate progress tracking (S4.2); enhance framework tooling with more downstream signaling information (S4.3)." .

<https://w3id.org/lmodel/slsa/AdoptionStrategyEnum#PROVIDE_DETAILED_DOCUMENTATION> a owl:Class ;
    rdfs:label "PROVIDE_DETAILED_DOCUMENTATION" ;
    rdfs:subClassOf slsa:AdoptionStrategyEnum ;
    skos:definition "(S2) Provide specific and detailed documentation: enhance docs with clear definitions, standard terms, revised requirements, and patches (S2.1); use negative examples to explain complex concepts and improve website diagrams and navigation (S2.2)." .

<https://w3id.org/lmodel/slsa/AdoptionStrategyEnum#STREAMLINE_PROVENANCE_GENERATION> a owl:Class ;
    rdfs:label "STREAMLINE_PROVENANCE_GENERATION" ;
    rdfs:subClassOf slsa:AdoptionStrategyEnum ;
    skos:definition "(S3) Streamline provenance generation processes: simplify and standardize the generation process via tools and templates to reduce confusion and improve consistency (S3.1); fix semantic-release tool inconsistencies with clear versioning rules and parallel pre-submit job execution (S3.2)." .

<https://w3id.org/lmodel/slsa/BuildEnvLevelEnum#SLSA_BUILD_ENV_LEVEL_0> a owl:Class ;
    rdfs:label "SLSA_BUILD_ENV_LEVEL_0" ;
    rdfs:subClassOf slsa:BuildEnvLevelEnum ;
    skos:definition "No build environment integrity requirements." .

<https://w3id.org/lmodel/slsa/BuildEnvLevelEnum#SLSA_BUILD_ENV_LEVEL_1> a owl:Class ;
    rdfs:label "SLSA_BUILD_ENV_LEVEL_1" ;
    rdfs:subClassOf slsa:BuildEnvLevelEnum ;
    skos:definition "Signed build image provenance exists, protecting against tampering during build image distribution to the build platform." .

<https://w3id.org/lmodel/slsa/BuildEnvLevelEnum#SLSA_BUILD_ENV_LEVEL_2> a owl:Class ;
    rdfs:label "SLSA_BUILD_ENV_LEVEL_2" ;
    rdfs:subClassOf slsa:BuildEnvLevelEnum ;
    skos:definition "The compute platform attests to the boot-time integrity of the build environment, providing evidence of correct instantiation." .

<https://w3id.org/lmodel/slsa/BuildEnvLevelEnum#SLSA_BUILD_ENV_LEVEL_3> a owl:Class ;
    rdfs:label "SLSA_BUILD_ENV_LEVEL_3" ;
    rdfs:subClassOf slsa:BuildEnvLevelEnum ;
    skos:definition "The build environment runs in a hardware-attested trusted execution environment (TEE), providing runtime integrity guarantees." .

slsa:BuildImage a owl:Class ;
    rdfs:label "BuildImage" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:provenance ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:provenance ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:buildEnvLevel ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:BuildProvenance ;
            owl:onProperty slsa:provenance ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:buildEnvLevel ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:BuildEnvLevelEnum ;
            owl:onProperty slsa:buildEnvLevel ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slsa:id ] ;
    skos:definition "The template for a build environment, such as a VM or container image. Comprises the root filesystem, pre-installed guest OS and packages, the build executor, and the build agent. Created by a build image producer and consumed by the hosted build platform." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

<https://w3id.org/lmodel/slsa/BuildLevelEnum#SLSA_BUILD_LEVEL_0> a owl:Class ;
    rdfs:label "SLSA_BUILD_LEVEL_0" ;
    rdfs:subClassOf slsa:BuildLevelEnum ;
    skos:definition "No SLSA requirements. Represents the absence of SLSA guarantees; intended for development or test builds." .

<https://w3id.org/lmodel/slsa/BuildLevelEnum#SLSA_BUILD_LEVEL_1> a owl:Class ;
    rdfs:label "SLSA_BUILD_LEVEL_1" ;
    rdfs:subClassOf slsa:BuildLevelEnum ;
    skos:definition "Provenance exists, showing how the package was built. Prevents mistakes and aids documentation, but is trivial to bypass." .

<https://w3id.org/lmodel/slsa/BuildLevelEnum#SLSA_BUILD_LEVEL_2> a owl:Class ;
    rdfs:label "SLSA_BUILD_LEVEL_2" ;
    rdfs:subClassOf slsa:BuildLevelEnum ;
    skos:definition "Build runs on a hosted platform that generates and signs provenance, deterring tampering after the build." ;
    skos:editorialNote "Implementation challenge (Tamanna et al., 2024, CI.2): Integrating hosted signing tools (e.g., Sigstore/cosign) into diverse CI/CD workflows is complex. Tool updates can introduce incompatibilities, silent workflow failures, and hard-coded values that complicate ongoing maintenance at this level." .

<https://w3id.org/lmodel/slsa/BuildLevelEnum#SLSA_BUILD_LEVEL_3> a owl:Class ;
    rdfs:label "SLSA_BUILD_LEVEL_3" ;
    rdfs:subClassOf slsa:BuildLevelEnum ;
    skos:definition "Hardened build platform providing strong guarantees against tampering during the build; requires exploiting a vulnerability to forge provenance." ;
    skos:editorialNote "Top adoption barrier (Tamanna et al., 2024, CI.1): Over 50% of practitioners surveyed by OpenSSF found hermetic build requirements difficult to implement. Non-build configurations (e.g., GoReleaser publish-only steps) lack explicit tool support. Use the hermeticBuild slot to record whether the isolation requirement is satisfied for a given BuildDefinition." .

slsa:BuildMetadata a owl:Class ;
    rdfs:label "BuildMetadata" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:finishedOn ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:startedOn ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:invocationId ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:finishedOn ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:invocationId ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:finishedOn ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:startedOn ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:startedOn ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:invocationId ] ;
    skos:definition "Metadata about a specific invocation of the build, including timing information and a unique build identifier for log correlation." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:BuildProvenance a owl:Class ;
    rdfs:label "BuildProvenance" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slsa:buildDefinition ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slsa:runDetails ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:RunDetails ;
            owl:onProperty slsa:runDetails ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:BuildDefinition ;
            owl:onProperty slsa:buildDefinition ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:runDetails ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:buildDefinition ],
        slsa:Statement ;
    skos:definition "An attestation predicate (predicateType \"https://slsa.dev/provenance/v1\") that describes how a set of output artifacts was produced by a build platform. Consumers use this to verify artifact authenticity and trace artifacts back through the supply chain." ;
    skos:editorialNote "Top adoption challenge (Tamanna et al., 2024, CI.1 — 901 issues): Generating valid provenance is the highest-volume challenge theme in practitioner GitHub issues. Key sub-challenges include the blocking nature of check-verifier pre-submit jobs, lack of support for non-build configurations (e.g., GoReleaser publish-only steps), laborious multi-build script setup, and risk of leaking credentials or other sensitive data in externalParameters." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:Builder a owl:Class ;
    rdfs:label "Builder" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:builderDependencies ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:versionTag ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:versionTag ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:version ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:versionTag ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slsa:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:version ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:version ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:ResourceDescriptor ;
            owl:onProperty slsa:builderDependencies ] ;
    skos:definition "Represents the transitive closure of all software, hardware, and entities trusted to faithfully execute the build and record provenance. The builder.id is the primary basis for determining SLSA Build Level." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

<https://w3id.org/lmodel/slsa/DependencyLevelEnum#SLSA_DEPENDENCY_LEVEL_0> a owl:Class ;
    rdfs:label "SLSA_DEPENDENCY_LEVEL_0" ;
    rdfs:subClassOf slsa:DependencyLevelEnum ;
    skos:definition "No mitigations to dependency threats." .

<https://w3id.org/lmodel/slsa/DependencyLevelEnum#SLSA_DEPENDENCY_LEVEL_1> a owl:Class ;
    rdfs:label "SLSA_DEPENDENCY_LEVEL_1" ;
    rdfs:subClassOf slsa:DependencyLevelEnum ;
    skos:definition "An inventory of all build dependencies (direct and transitive) exists." .

<https://w3id.org/lmodel/slsa/DependencyLevelEnum#SLSA_DEPENDENCY_LEVEL_2> a owl:Class ;
    rdfs:label "SLSA_DEPENDENCY_LEVEL_2" ;
    rdfs:subClassOf slsa:DependencyLevelEnum ;
    skos:definition "All known vulnerabilities in the artifact's dependencies have been triaged before each release." .

<https://w3id.org/lmodel/slsa/DependencyLevelEnum#SLSA_DEPENDENCY_LEVEL_3> a owl:Class ;
    rdfs:label "SLSA_DEPENDENCY_LEVEL_3" ;
    rdfs:subClassOf slsa:DependencyLevelEnum ;
    skos:definition "All third-party build dependencies are consumed exclusively from locations under the producer's control." .

<https://w3id.org/lmodel/slsa/DependencyLevelEnum#SLSA_DEPENDENCY_LEVEL_4> a owl:Class ;
    rdfs:label "SLSA_DEPENDENCY_LEVEL_4" ;
    rdfs:subClassOf slsa:DependencyLevelEnum ;
    skos:definition "Proactive defense against upstream attacks; an ingestion policy prevents consumption of compromised dependencies." .

slsa:DigestSet a owl:Class ;
    rdfs:label "DigestSet" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:sha512 ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:gitCommit ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:sha256 ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:sha256 ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:sha512 ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:sha512 ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:gitCommit ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:gitCommit ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:sha256 ] ;
    skos:definition "A set of cryptographic digests for an artifact, keyed by algorithm name (e.g., \"sha256\", \"gitCommit\"). Provides enough information for consumers to verify artifact integrity using their preferred algorithm." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

<https://w3id.org/lmodel/slsa/ReviewTypeEnum#AUTOMATED> a owl:Class ;
    rdfs:label "AUTOMATED" ;
    rdfs:subClassOf slsa:ReviewTypeEnum ;
    skos:definition "Review performed entirely by an automated tool or bot, without a second human reviewer. Does not satisfy the SLSA trusted-persons requirement for Source Level 4." .

<https://w3id.org/lmodel/slsa/ReviewTypeEnum#MOB_PROGRAMMING> a owl:Class ;
    rdfs:label "MOB_PROGRAMMING" ;
    rdfs:subClassOf slsa:ReviewTypeEnum ;
    skos:definition "Collaborative development with a whole group at once. As with pair programming, formal equivalence to asynchronous two-party review has not been established for SLSA purposes (Tamanna et al., 2024, LF.2)." .

<https://w3id.org/lmodel/slsa/ReviewTypeEnum#PAIR_PROGRAMMING> a owl:Class ;
    rdfs:label "PAIR_PROGRAMMING" ;
    rdfs:subClassOf slsa:ReviewTypeEnum ;
    skos:definition "Two developers working simultaneously on the same code at the same workstation or via screen-sharing. Whether this satisfies the trusted-persons two-party review requirement is an open question raised in practitioner discussions (Tamanna et al., 2024, LF.2)." .

<https://w3id.org/lmodel/slsa/ReviewTypeEnum#TWO_PARTY> a owl:Class ;
    rdfs:label "TWO_PARTY" ;
    rdfs:subClassOf slsa:ReviewTypeEnum ;
    skos:definition "Standard two-party review: a change is approved by at least one reviewer who is distinct from the author, where both the author and reviewer are trusted persons as defined by the organization." .

<https://w3id.org/lmodel/slsa/SlsaResultEnum#SLSA_BUILD_LEVEL_0> a owl:Class ;
    rdfs:label "SLSA_BUILD_LEVEL_0" ;
    rdfs:subClassOf slsa:SlsaResultEnum ;
    skos:definition "No SLSA Build guarantees verified." .

<https://w3id.org/lmodel/slsa/SlsaResultEnum#SLSA_BUILD_LEVEL_1> a owl:Class ;
    rdfs:label "SLSA_BUILD_LEVEL_1" ;
    rdfs:subClassOf slsa:SlsaResultEnum ;
    skos:definition "Build Level 1 verified for the artifact." .

<https://w3id.org/lmodel/slsa/SlsaResultEnum#SLSA_BUILD_LEVEL_2> a owl:Class ;
    rdfs:label "SLSA_BUILD_LEVEL_2" ;
    rdfs:subClassOf slsa:SlsaResultEnum ;
    skos:definition "Build Level 2 verified for the artifact." .

<https://w3id.org/lmodel/slsa/SlsaResultEnum#SLSA_BUILD_LEVEL_3> a owl:Class ;
    rdfs:label "SLSA_BUILD_LEVEL_3" ;
    rdfs:subClassOf slsa:SlsaResultEnum ;
    skos:definition "Build Level 3 verified for the artifact." .

<https://w3id.org/lmodel/slsa/SlsaResultEnum#SLSA_SOURCE_LEVEL_1> a owl:Class ;
    rdfs:label "SLSA_SOURCE_LEVEL_1" ;
    rdfs:subClassOf slsa:SlsaResultEnum ;
    skos:definition "Source Level 1 verified for the artifact." .

<https://w3id.org/lmodel/slsa/SlsaResultEnum#SLSA_SOURCE_LEVEL_2> a owl:Class ;
    rdfs:label "SLSA_SOURCE_LEVEL_2" ;
    rdfs:subClassOf slsa:SlsaResultEnum ;
    skos:definition "Source Level 2 verified for the artifact." .

<https://w3id.org/lmodel/slsa/SlsaResultEnum#SLSA_SOURCE_LEVEL_3> a owl:Class ;
    rdfs:label "SLSA_SOURCE_LEVEL_3" ;
    rdfs:subClassOf slsa:SlsaResultEnum ;
    skos:definition "Source Level 3 verified for the artifact." .

<https://w3id.org/lmodel/slsa/SlsaResultEnum#SLSA_SOURCE_LEVEL_4> a owl:Class ;
    rdfs:label "SLSA_SOURCE_LEVEL_4" ;
    rdfs:subClassOf slsa:SlsaResultEnum ;
    skos:definition "Source Level 4 verified for the artifact." .

<https://w3id.org/lmodel/slsa/SourceLevelEnum#SLSA_SOURCE_LEVEL_1> a owl:Class ;
    rdfs:label "SLSA_SOURCE_LEVEL_1" ;
    rdfs:subClassOf slsa:SourceLevelEnum ;
    skos:definition "Source is stored in a version control system, enabling discrete and immutable source revisions for precise consumption." .

<https://w3id.org/lmodel/slsa/SourceLevelEnum#SLSA_SOURCE_LEVEL_2> a owl:Class ;
    rdfs:label "SLSA_SOURCE_LEVEL_2" ;
    rdfs:subClassOf slsa:SourceLevelEnum ;
    skos:definition "Branch history is preserved and immutable; the SCS generates tamper- resistant source provenance attestations for each new revision." .

<https://w3id.org/lmodel/slsa/SourceLevelEnum#SLSA_SOURCE_LEVEL_3> a owl:Class ;
    rdfs:label "SLSA_SOURCE_LEVEL_3" ;
    rdfs:subClassOf slsa:SourceLevelEnum ;
    skos:definition "The SCS enforces the organization's technical controls on protected Named References, providing verifiable evidence of those controls." .

<https://w3id.org/lmodel/slsa/SourceLevelEnum#SLSA_SOURCE_LEVEL_4> a owl:Class ;
    rdfs:label "SLSA_SOURCE_LEVEL_4" ;
    rdfs:subClassOf slsa:SourceLevelEnum ;
    skos:definition "All changes to protected branches require two-party review by trusted persons, resisting insider threats and unilateral changes." ;
    skos:editorialNote "Feasibility concern (Tamanna et al., 2024, LF.2): Many open-source projects have only one active maintainer, making the two-party review requirement impractical. Whether pair programming and mob programming qualify as equivalent review forms is an open question in the practitioner community. Use the reviewType slot on SourceRevision to record the form of review applied." .

slsa:SourceRepository a owl:Class ;
    rdfs:label "SourceRepository" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:sourceLevel ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:sourceLevel ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:SourceLevelEnum ;
            owl:onProperty slsa:sourceLevel ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slsa:id ] ;
    skos:definition "A self-contained unit that holds the content and complete revision history for a set of files, along with metadata such as branches and tags. Hosted and governed by a Source Control System." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:SourceRevision a owl:Class ;
    rdfs:label "SourceRevision" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:parentRevisions ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:repository ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:ReviewTypeEnum ;
            owl:onProperty slsa:reviewType ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slsa:revisionId ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:timestamp ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:revisionId ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:parentRevisions ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:reviewType ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:author ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:repository ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:timestamp ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:SourceRepository ;
            owl:onProperty slsa:repository ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:author ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:author ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:timestamp ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:revisionId ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:reviewType ] ;
    skos:definition "A specific, logically immutable snapshot of a source repository's tracked files. Uniquely identified by a revision identifier such as a cryptographic hash (e.g., git commit SHA) or a path-qualified sequential number (e.g., SVN)." ;
    skos:editorialNote "if SourceRevision ever needs signingTool/sigstoreLogEntry (for  Sigstore-signed git tags via Cosign, gittuf), then consider adding  a SigstoreSignable mixin on both Statement and SourceRevision" ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

<https://w3id.org/lmodel/slsa/VerificationResultEnum#FAILED> a owl:Class ;
    rdfs:label "FAILED" ;
    rdfs:subClassOf slsa:VerificationResultEnum ;
    skos:definition "The artifact did not satisfy one or more policy requirements." .

<https://w3id.org/lmodel/slsa/VerificationResultEnum#PASSED> a owl:Class ;
    rdfs:label "PASSED" ;
    rdfs:subClassOf slsa:VerificationResultEnum ;
    skos:definition "The artifact satisfied all policy requirements." .

slsa:annotations a owl:DatatypeProperty ;
    rdfs:label "annotations" ;
    skos:definition "Arbitrary vendor-specific key-value annotations." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:builderDependencies a owl:ObjectProperty ;
    rdfs:label "builderDependencies" ;
    rdfs:range slsa:ResourceDescriptor ;
    skos:definition "Dependencies used by the control plane orchestrator that are not run within the build workload but may affect provenance generation or security guarantees." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:byproducts a owl:ObjectProperty ;
    rdfs:label "byproducts" ;
    rdfs:range slsa:ResourceDescriptor ;
    skos:definition "Additional artifacts produced during the build that are NOT the primary output but may be useful for debugging or incident response (e.g., build logs, intermediate artifacts)." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:challenges a owl:ObjectProperty ;
    rdfs:label "challenges" ;
    rdfs:range slsa:AdoptionChallengeEnum ;
    skos:definition "The adoption challenge themes that apply to this attestation or deployment context, drawn from the empirically identified challenge taxonomy (Tamanna et al., 2024, arXiv:2409.05014)." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:controlsEnforced a owl:DatatypeProperty ;
    rdfs:label "controlsEnforced" ;
    skos:definition "Technical controls actively enforced by the Source Control System when this revision was created (e.g., \"two-party review\", \"branch protection\", \"status checks\")." ;
    skos:editorialNote "Two-party review feasibility (Tamanna et al., 2024, LF.2): Many open-source projects have a single maintainer, making the two-party review requirement impractical. Pair programming and mob programming were raised as contested alternatives whose security equivalence has not been formally established. Use the reviewType slot on SourceRevision to record the specific form of review applied." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:dependencies a owl:ObjectProperty ;
    rdfs:label "dependencies" ;
    rdfs:range slsa:ResourceDescriptor ;
    skos:definition "All third-party build dependencies (direct and transitive) for an artifact version, identified by URI and digest." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:inputAttestations a owl:ObjectProperty ;
    rdfs:label "inputAttestations" ;
    rdfs:range slsa:ResourceDescriptor ;
    skos:definition "All attestations consulted during verification. If non-empty, MUST be complete — it MUST list every attestation used. Each entry MUST contain a digest; SHOULD contain a URI." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:measurements a owl:DatatypeProperty ;
    rdfs:label "measurements" ;
    skos:definition "Cryptographic measurements (hashes) of build environment components captured during boot and initialization, used to verify integrity against known-good reference values." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:parentRevisions a owl:DatatypeProperty ;
    rdfs:label "parentRevisions" ;
    skos:definition "Revision IDs of the parent revision(s), forming the directed acyclic graph of change history." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:resolvedDependencies a owl:ObjectProperty ;
    rdfs:label "resolvedDependencies" ;
    rdfs:range slsa:ResourceDescriptor ;
    skos:definition "Unordered collection of artifacts needed at build time (config files, source, build tools). Completeness is best effort through SLSA Build L3." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:strategies a owl:ObjectProperty ;
    rdfs:label "strategies" ;
    rdfs:range slsa:AdoptionStrategyEnum ;
    skos:definition "The mitigation strategies being employed or recommended in this attestation or deployment context, drawn from the empirically identified strategy taxonomy (Tamanna et al., 2024, arXiv:2409.05014)." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:subject a owl:ObjectProperty ;
    rdfs:label "subject" ;
    rdfs:range slsa:ResourceDescriptor ;
    skos:definition "The set of software artifacts to which a predicate applies. Each entry MUST contain a digest." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:BuildDefinition a owl:Class ;
    rdfs:label "BuildDefinition" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty slsa:hermeticBuild ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:pipelineOrchestrator ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:buildType ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:buildType ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:internalParameters ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:internalParameters ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:hermeticBuild ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:provenanceGenerationTool ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:externalParameters ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slsa:buildType ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:pipelineOrchestrator ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:provenanceGenerationTool ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:externalParameters ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:provenanceGenerationTool ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:externalParameters ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:pipelineOrchestrator ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:internalParameters ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:ResourceDescriptor ;
            owl:onProperty slsa:resolvedDependencies ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:resolvedDependencies ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:hermeticBuild ] ;
    skos:definition "Describes all inputs to the build in enough detail to initialise and reproduce the build. The accuracy and completeness are implied by the builder identified in runDetails." ;
    skos:editorialNote "Hermetic build challenge (Tamanna et al., 2024, CI.1): Over 50% of practitioners surveyed by OpenSSF found hermetic builds difficult to implement. Non-build configurations (e.g., GoReleaser publish-only steps) lack explicit hermetic-build tool support. Use hermeticBuild to record whether L3 isolation is satisfied.",
        "Provenance generation standardization (Tamanna et al., 2024, S3.1): Recording which tool generated this provenance via provenanceGenerationTool supports standardization, reproducibility verification, and incident response." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:RunDetails a owl:Class ;
    rdfs:label "RunDetails" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:builder ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:BuildMetadata ;
            owl:onProperty slsa:buildMetadata ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:buildMetadata ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:Builder ;
            owl:onProperty slsa:builder ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:buildMetadata ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slsa:builder ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:byproducts ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:ResourceDescriptor ;
            owl:onProperty slsa:byproducts ] ;
    skos:definition "Details specific to this particular execution of the build, including the trusted builder and optional run-level metadata." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:Verifier a owl:Class ;
    rdfs:label "Verifier" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:version ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slsa:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:version ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:version ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:id ] ;
    skos:definition "The entity that performed verification of an artifact and issued a Verification Summary Attestation. Consumers MUST accept only specific (signer, verifier) pairs." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:_type a owl:DatatypeProperty ;
    rdfs:label "_type" ;
    skos:definition "Always \"https://in-toto.io/Statement/v1\". Identifies the in-toto statement schema version and namespace." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:adoptionMetadata a owl:ObjectProperty ;
    rdfs:label "adoptionMetadata" ;
    rdfs:range slsa:AdoptionMetadata ;
    skos:definition "Optional structured metadata recording the SLSA adoption challenges and mitigation strategies relevant to this attestation context. Derived from empirical analysis of SLSA-related GitHub issues (Tamanna et al., 2024, arXiv:2409.05014). Intended for use by framework authors, practitioners, and tooling that tracks adoption progress alongside attestation payloads." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:attestationStorageUri a owl:DatatypeProperty ;
    rdfs:label "attestationStorageUri" ;
    skos:definition "URI indicating where this signed attestation is publicly stored or retrievable. No universal standard for attestation storage location was established in SLSA v1.0; Sigstore and VCS-embedded storage are two common approaches. Explicitly recording this URI addresses the storage ambiguity identified as a significant adoption barrier: practitioners reported uncertainty about where generated attestations should be stored (Tamanna et al., 2024, LF.1)." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:author a owl:DatatypeProperty ;
    rdfs:label "author" ;
    skos:definition "Identity of the person or automation that authored this revision (e.g., an email address or platform username)." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:buildId a owl:DatatypeProperty ;
    rdfs:label "buildId" ;
    skos:definition "An immutable identifier uniquely assigned to a build execution (e.g., a UUID). Links a BuildEnvironmentAttestation to the corresponding build provenance." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:buildImage a owl:ObjectProperty ;
    rdfs:label "buildImage" ;
    rdfs:range slsa:BuildImage ;
    skos:definition "The build image from which the build environment was instantiated." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:buildLevel a owl:ObjectProperty ;
    rdfs:label "buildLevel" ;
    rdfs:range slsa:BuildLevelEnum ;
    skos:definition "The SLSA Build Level this platform is capable of producing, as determined by its provenance generation and isolation guarantees." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:buildMetadata a owl:ObjectProperty ;
    rdfs:label "buildMetadata" ;
    rdfs:range slsa:BuildMetadata ;
    skos:definition "Metadata about this particular build execution." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:buildPlatformId a owl:DatatypeProperty ;
    rdfs:label "buildPlatformId" ;
    skos:definition "URI of the build platform chosen to produce artifacts." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:buildType a owl:DatatypeProperty ;
    rdfs:label "buildType" ;
    skos:definition "URI identifying the template for how to perform the build and how to interpret the parameters and dependencies. SHOULD resolve to a human-readable specification. REQUIRED at SLSA Build L1." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:builder a owl:ObjectProperty ;
    rdfs:label "builder" ;
    rdfs:range slsa:Builder ;
    skos:definition "Identifies the build platform that executed the build and is trusted to have correctly generated this provenance. REQUIRED at SLSA Build L1." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:dependencyLevel a owl:ObjectProperty ;
    rdfs:label "dependencyLevel" ;
    rdfs:range slsa:DependencyLevelEnum ;
    skos:definition "The SLSA Dependency Level that this inventory and associated triage process supports." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:dependencyLevels a owl:DatatypeProperty ;
    rdfs:label "dependencyLevels" ;
    skos:definition "Map from SlsaResult to count of transitive dependencies verified at that level (JSON object string). Allows policy engines to enforce minimum levels on the full dependency graph." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:description a owl:DatatypeProperty ;
    rdfs:label "description" ;
    skos:definition "Human-readable description of a repository's purpose or a resource." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:digest a owl:ObjectProperty ;
    rdfs:label "digest" ;
    rdfs:range slsa:DigestSet ;
    skos:definition "Set of cryptographic digests of a resource's content used for integrity verification." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:downloadLocation a owl:DatatypeProperty ;
    rdfs:label "downloadLocation" ;
    skos:definition "URI from which a resource can be downloaded, if different from its identifying URI." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:ecosystem a owl:DatatypeProperty ;
    rdfs:label "ecosystem" ;
    skos:definition "The package ecosystem (e.g., \"PyPA\", \"npm\", \"OCI\", \"cargo\") governing distribution conventions for this package." ;
    skos:editorialNote "Ecosystem naming inconsistency can undermine attestation accuracy (Tamanna et al., 2024, UR.1): For example, \"npm install P\" produces package name A while \"npm download P && npm install P.tar.gz\" produces name B from the same source, causing metadata and provenance mismatches that persist even with lock files. Policy engines must account for these cross-registry naming discrepancies when verifying provenance." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:externalParameters a owl:DatatypeProperty ;
    rdfs:label "externalParameters" ;
    skos:definition "Top-level, independent inputs under external (tenant or user) control. MUST be complete at SLSA Build L3. Stored as a JSON object. Verifiers SHOULD reject unrecognized fields." ;
    skos:editorialNote "SSF pipeline definition files (CNCF TAG-Security Secure Software Factory): In Tekton-based SSF pipelines, externalParameters typically contains the PipelineRun YAML reference or TaskRun definition URI. For GitHub Actions, it would contain the workflow file path and ref. These values MUST be complete and verifiable at SLSA Build L3 so that consumers can confirm the exact build recipe. Use pipelineOrchestrator to record the CI system and provenanceGenerationTool (in BuildDefinition) to record the attestation generator (e.g., Tekton Chains)." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:finishedOn a owl:DatatypeProperty ;
    rdfs:label "finishedOn" ;
    skos:definition "Timestamp (RFC 3339) of when the build completed." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:gitCommit a owl:DatatypeProperty ;
    rdfs:label "gitCommit" ;
    skos:definition "Git commit SHA identifying a source-backed artifact." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:hermeticBuild a owl:DatatypeProperty ;
    rdfs:label "hermeticBuild" ;
    rdfs:range xsd:boolean ;
    skos:definition "Whether all build inputs are fully isolated to the dependencies declared in resolvedDependencies, with no network access or filesystem references outside the explicit build graph. Hermetic builds are a stated requirement for SLSA Build L3; practitioners identified this as one of the most commonly cited implementation barriers, with over 50% of surveyed practitioners finding hermetic build requirements difficult to implement (Tamanna et al., 2024, CI.1)." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:internalParameters a owl:DatatypeProperty ;
    rdfs:label "internalParameters" ;
    skos:definition "Parameters set internally by the build platform. Intended for debugging, incident response, and enabling reproducible builds. Stored as a JSON object; need not be verified by consumers." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:invocationId a owl:DatatypeProperty ;
    rdfs:label "invocationId" ;
    skos:definition "A globally unique identifier for a build invocation, useful for finding associated logs. Format defined by builder.id; treated as opaque and case-sensitive. The value SHOULD be globally unique." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:isHosted a owl:DatatypeProperty ;
    rdfs:label "isHosted" ;
    rdfs:range xsd:boolean ;
    skos:definition "True if this is a hosted (multi-tenant) platform running on shared or dedicated infrastructure, rather than an individual's workstation. Required for SLSA Build L2+." ;
    skos:editorialNote "SSF reference architecture (CNCF TAG-Security): Hosted, multi-tenant build services (GitHub Actions, Google Cloud Build, GitLab CI/CD, CircleCI) are the recommended Build Service layer in the SSF pattern. Using a hosted service is a prerequisite for SLSA Build L2 because it provides the separation of concerns that prevents tenants from tampering with provenance generated by the control plane. Self-hosted runners can be used at SLSA Build L2+ only if they replicate the isolation guarantees of hosted services." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:mediaType a owl:DatatypeProperty ;
    rdfs:label "mediaType" ;
    skos:definition "IANA media type of a resource's content (e.g., \"application/octet-stream\", \"application/vnd.oci.image.manifest.v1+json\")." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:pipelineOrchestrator a owl:DatatypeProperty ;
    rdfs:label "pipelineOrchestrator" ;
    skos:definition "URI or name of the CI/CD pipeline orchestration system that coordinated this build (e.g., \"https://tekton.dev\", \"https://github.com/features/actions\", \"https://jenkins.io\"). In the SSF reference architecture this is the Build Service layer that feeds the Artifact Registry. Providing this field helps distinguish the orchestrator from the provenance-generating builder identity (builder.id) in complex deployments where they differ (e.g., a Tekton Pipeline running on Google Cloud Pipelines)." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:policy a owl:ObjectProperty ;
    rdfs:label "policy" ;
    rdfs:range slsa:ResourceDescriptor ;
    skos:definition "The policy the subject was verified against. MUST contain a URI; SHOULD contain a digest identifying the exact policy version." ;
    skos:editorialNote "SSF Policy Engine layer (CNCF TAG-Security): In the SSF reference architecture, the policy consumed here is enforced at admission time by a Policy Engine such as OPA/Gatekeeper or Kyverno. These engines consume Verification Summary Attestations (VSAs) to verify that an artifact meets the required SLSA level before allowing deployment. Best practice is to reference a versioned, content-addressed policy document so verifiers can reconstruct the exact policy evaluated." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:predicate a owl:DatatypeProperty ;
    rdfs:label "predicate" ;
    skos:definition "The attestation payload — an arbitrary JSON object whose schema is fully determined by predicateType." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:predicateType a owl:DatatypeProperty ;
    rdfs:label "predicateType" ;
    skos:definition "URI identifying the schema and semantics of the predicate field. Used to distinguish different attestation types (e.g., SLSA Provenance vs. Verification Summary Attestation)." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:provenance a owl:ObjectProperty ;
    rdfs:label "provenance" ;
    rdfs:range slsa:BuildProvenance ;
    skos:definition "SLSA Build Provenance for a build image, describing how the image itself was produced. Required for SLSA Build Environment L1+." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:provenanceGenerationTool a owl:DatatypeProperty ;
    rdfs:label "provenanceGenerationTool" ;
    skos:definition "URI or name of the tool used to generate provenance for this build (e.g., \"https://github.com/slsa-framework/slsa-github-generator\"). Standardizing this field across builds reduces confusion, supports reproducibility verification, and aligns with the recommended strategy of simplifying and standardizing provenance generation processes (Tamanna et al., 2024, S3.1)." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:registry a owl:DatatypeProperty ;
    rdfs:label "registry" ;
    skos:definition "URI of the package registry where a package is published and from which consumers resolve the package name to an artifact." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:repository a owl:ObjectProperty ;
    rdfs:label "repository" ;
    rdfs:range slsa:SourceRepository ;
    skos:definition "The source repository that contains this revision." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:resourceUri a owl:DatatypeProperty ;
    rdfs:label "resourceUri" ;
    skos:definition "URI identifying the resource associated with the artifact being verified. SHOULD be the URI from which the consumer fetches the artifact." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:reviewType a owl:ObjectProperty ;
    rdfs:label "reviewType" ;
    rdfs:range slsa:ReviewTypeEnum ;
    skos:definition "The type of human or automated review process used to approve this source revision. Captures the contested forms of two-party review — including pair programming and mob programming — whose security equivalence to standard asynchronous two-party review is an open question identified in practitioner community discussions (Tamanna et al., 2024, LF.2). See ReviewTypeEnum for defined values." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:revision a owl:ObjectProperty ;
    rdfs:label "revision" ;
    rdfs:range slsa:SourceRevision ;
    skos:definition "The source revision that this attestation describes." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:revisionId a owl:DatatypeProperty ;
    rdfs:label "revisionId" ;
    skos:definition "Immutable identifier for a source revision (e.g., git commit SHA, path-qualified sequential number)." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:sha256 a owl:DatatypeProperty ;
    rdfs:label "sha256" ;
    skos:definition "Lowercase hex-encoded SHA-256 digest of the artifact." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:sha512 a owl:DatatypeProperty ;
    rdfs:label "sha512" ;
    skos:definition "Lowercase hex-encoded SHA-512 digest of the artifact." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:signingTool a owl:DatatypeProperty ;
    rdfs:label "signingTool" ;
    skos:definition "URI or name of the tool used to cryptographically sign the artifact or attestation (e.g., \"https://github.com/sigstore/cosign\", \"https://github.com/notaryproject/notation\"). In the SSF reference architecture the Signing Service layer is distinct from the Build Service; recording the signing tool enables verifiers to select the matching verification workflow. For Sigstore keyless signing the value should be the Cosign release URI." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:sigstoreLogEntry a owl:DatatypeProperty ;
    rdfs:label "sigstoreLogEntry" ;
    skos:definition "URI of the Rekor transparency log entry recording this attestation or artifact signature (e.g., \"https://rekor.sigstore.dev/api/v1/log/entries/24296fb...\"). The Rekor log provides an immutable, auditable record of signing events that underpins Sigstore keyless signing. Verifiers can fetch this entry to confirm the cryptographic signature was recorded in the public-good log and obtain the signing certificate chain issued by Fulcio. Recording this URI enables offline and third-party verification without requiring direct access to the original signing key." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:slsaVersion a owl:DatatypeProperty ;
    rdfs:label "slsaVersion" ;
    skos:definition "Version of the SLSA specification used during verification, in MAJOR.MINOR format (e.g., \"1.0\")." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:startedOn a owl:DatatypeProperty ;
    rdfs:label "startedOn" ;
    skos:definition "Timestamp (RFC 3339) of when the build started." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:timeVerified a owl:DatatypeProperty ;
    rdfs:label "timeVerified" ;
    skos:definition "Timestamp (RFC 3339) indicating when the verification occurred." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:timestamp a owl:DatatypeProperty ;
    rdfs:label "timestamp" ;
    skos:definition "Timestamp (RFC 3339) of when this source revision was created." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:uri a owl:DatatypeProperty ;
    rdfs:label "uri" ;
    skos:definition "A URI uniquely identifying a resource, such as a package URL (purl), git repository URL, or OCI image reference." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:versionTag a owl:DatatypeProperty ;
    rdfs:label "versionTag" ;
    skos:definition "A semantic version tag (e.g., \"v1.2.3\") assigned to the builder or the produced artifact at the time of the build. Practitioners recommended implementing versioning tagging early in SLSA framework deployment to facilitate progress tracking, reduce maintenance confusion from breaking changes, and enable more straightforward verification (Tamanna et al., 2024, S4.2)." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:Statement a owl:Class ;
    rdfs:label "Statement" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:predicateType ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:signingTool ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:signingTool ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:attestationStorageUri ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:predicate ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slsa:predicateType ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:predicate ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:_type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slsa:_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:ResourceDescriptor ;
            owl:onProperty slsa:subject ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:predicateType ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:attestationStorageUri ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:predicate ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:signingTool ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:attestationStorageUri ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty slsa:subject ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:sigstoreLogEntry ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:sigstoreLogEntry ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:sigstoreLogEntry ] ;
    skos:definition "The middle layer of an in-toto software attestation (Statement v1). Binds an authenticated predicate to one or more subject artifacts, allowing predicate-agnostic processing and storage." ;
    skos:editorialNote "Attestation storage gap (Tamanna et al., 2024, LF.1): No standardized location for publishing signed attestations was defined in SLSA v1.0. Sigstore and VCS-embedded storage are two common approaches. Use the attestationStorageUri slot to record where this statement is stored.",
        "Terminology clarity (Tamanna et al., 2024, UC.1): Practitioners report widespread confusion between \"attestation\" and \"provenance\". An attestation is this signed Statement wrapper; provenance is the specific BuildProvenance predicate payload. Documenting this distinction addresses the most frequently cited terminology barrier." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:verifiedLevels a owl:ObjectProperty ;
    rdfs:label "verifiedLevels" ;
    rdfs:range slsa:SlsaResultEnum ;
    skos:definition "The highest verified SLSA level for each applicable track (not including transitive dependencies). At most one level per track. Implies all levels below it within the same track." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:VerificationResultEnum a owl:Class ;
    rdfs:label "VerificationResultEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/slsa/VerificationResultEnum#PASSED> <https://w3id.org/lmodel/slsa/VerificationResultEnum#FAILED> ) ;
    skos:definition "Outcome of a policy verification check on an artifact." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> ;
    linkml:permissible_values <https://w3id.org/lmodel/slsa/VerificationResultEnum#FAILED>,
        <https://w3id.org/lmodel/slsa/VerificationResultEnum#PASSED> .

slsa:AdoptionChallengeEnum a owl:Class ;
    rdfs:label "AdoptionChallengeEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/slsa/AdoptionChallengeEnum#COMPLEX_IMPLEMENTATION> <https://w3id.org/lmodel/slsa/AdoptionChallengeEnum#UNCLEAR_COMMUNICATION> <https://w3id.org/lmodel/slsa/AdoptionChallengeEnum#LIMITED_FEASIBILITY> <https://w3id.org/lmodel/slsa/AdoptionChallengeEnum#UNCLEAR_RELEVANCE> ) ;
    skos:definition "The four empirically identified themes of challenges practitioners encounter when deploying SLSA, derived from thematic analysis of 1,523 SLSA-related GitHub issues across 233 repositories (Tamanna et al., 2024, arXiv:2409.05014). Challenge counts in parentheses reflect total issues associated with each theme." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> ;
    linkml:permissible_values <https://w3id.org/lmodel/slsa/AdoptionChallengeEnum#COMPLEX_IMPLEMENTATION>,
        <https://w3id.org/lmodel/slsa/AdoptionChallengeEnum#LIMITED_FEASIBILITY>,
        <https://w3id.org/lmodel/slsa/AdoptionChallengeEnum#UNCLEAR_COMMUNICATION>,
        <https://w3id.org/lmodel/slsa/AdoptionChallengeEnum#UNCLEAR_RELEVANCE> .

slsa:BuildLevelEnum a owl:Class ;
    rdfs:label "BuildLevelEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/slsa/BuildLevelEnum#SLSA_BUILD_LEVEL_0> <https://w3id.org/lmodel/slsa/BuildLevelEnum#SLSA_BUILD_LEVEL_1> <https://w3id.org/lmodel/slsa/BuildLevelEnum#SLSA_BUILD_LEVEL_2> <https://w3id.org/lmodel/slsa/BuildLevelEnum#SLSA_BUILD_LEVEL_3> ) ;
    skos:definition "SLSA Build Track levels providing increasing supply chain security guarantees for the build process. Higher levels require stronger tamper-resistance and provenance integrity." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> ;
    linkml:permissible_values <https://w3id.org/lmodel/slsa/BuildLevelEnum#SLSA_BUILD_LEVEL_0>,
        <https://w3id.org/lmodel/slsa/BuildLevelEnum#SLSA_BUILD_LEVEL_1>,
        <https://w3id.org/lmodel/slsa/BuildLevelEnum#SLSA_BUILD_LEVEL_2>,
        <https://w3id.org/lmodel/slsa/BuildLevelEnum#SLSA_BUILD_LEVEL_3> .

slsa:ReviewTypeEnum a owl:Class ;
    rdfs:label "ReviewTypeEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/slsa/ReviewTypeEnum#TWO_PARTY> <https://w3id.org/lmodel/slsa/ReviewTypeEnum#PAIR_PROGRAMMING> <https://w3id.org/lmodel/slsa/ReviewTypeEnum#MOB_PROGRAMMING> <https://w3id.org/lmodel/slsa/ReviewTypeEnum#AUTOMATED> ) ;
    skos:definition "Categories of code-review process applied to a source revision. Captures the forms of two-party review discussed by practitioners (Tamanna et al., 2024, LF.2), including contested alternatives whose security equivalence with standard asynchronous two-party review has not been formally established." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> ;
    linkml:permissible_values <https://w3id.org/lmodel/slsa/ReviewTypeEnum#AUTOMATED>,
        <https://w3id.org/lmodel/slsa/ReviewTypeEnum#MOB_PROGRAMMING>,
        <https://w3id.org/lmodel/slsa/ReviewTypeEnum#PAIR_PROGRAMMING>,
        <https://w3id.org/lmodel/slsa/ReviewTypeEnum#TWO_PARTY> .

slsa:artifact a owl:ObjectProperty ;
    rdfs:label "artifact" ;
    rdfs:range slsa:ResourceDescriptor ;
    skos:definition "A specific immutable package artifact or the artifact whose dependency inventory is recorded." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:buildDefinition a owl:ObjectProperty ;
    rdfs:label "buildDefinition" ;
    rdfs:range slsa:BuildDefinition ;
    skos:definition "All inputs to the build, sufficient to initialise and reproduce it. REQUIRED at SLSA Build L1." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:buildEnvLevel a owl:ObjectProperty ;
    rdfs:label "buildEnvLevel" ;
    rdfs:range slsa:BuildEnvLevelEnum ;
    skos:definition "The SLSA Build Environment Level supported or represented, reflecting the strength of the integrity guarantees provided." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:runDetails a owl:ObjectProperty ;
    rdfs:label "runDetails" ;
    rdfs:range slsa:RunDetails ;
    skos:definition "Details specific to this particular execution of the build, including builder identity and metadata. REQUIRED at SLSA Build L1." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:sourceLevel a owl:ObjectProperty ;
    rdfs:label "sourceLevel" ;
    rdfs:range slsa:SourceLevelEnum ;
    skos:definition "The SLSA Source Level achieved or verified for a source repository or revision." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:verificationResult a owl:ObjectProperty ;
    rdfs:label "verificationResult" ;
    rdfs:range slsa:VerificationResultEnum ;
    skos:definition "Whether the artifact passed or failed policy verification." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:verifier a owl:ObjectProperty ;
    rdfs:label "verifier" ;
    rdfs:range slsa:Verifier ;
    skos:definition "Identifies the entity that performed the verification." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:version a owl:DatatypeProperty ;
    rdfs:label "version" ;
    skos:definition "Map of component names to their version strings, represented as a JSON object (string → string)." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:AdoptionStrategyEnum a owl:Class ;
    rdfs:label "AdoptionStrategyEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/slsa/AdoptionStrategyEnum#ENHANCE_ALIGNMENT_FLEXIBILITY> <https://w3id.org/lmodel/slsa/AdoptionStrategyEnum#PROVIDE_DETAILED_DOCUMENTATION> <https://w3id.org/lmodel/slsa/AdoptionStrategyEnum#STREAMLINE_PROVENANCE_GENERATION> <https://w3id.org/lmodel/slsa/AdoptionStrategyEnum#IMPROVE_VERIFICATION_PROCESS> <https://w3id.org/lmodel/slsa/AdoptionStrategyEnum#COLLABORATE_WITH_COMMUNITY> ) ;
    skos:definition "The five empirically identified themes of strategies practitioners suggested to overcome SLSA adoption challenges, derived from thematic analysis of 1,523 SLSA-related GitHub issues (Tamanna et al., 2024, arXiv:2409.05014). Each strategy theme contains 2–4 sub-strategies (13 total)." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> ;
    linkml:permissible_values <https://w3id.org/lmodel/slsa/AdoptionStrategyEnum#COLLABORATE_WITH_COMMUNITY>,
        <https://w3id.org/lmodel/slsa/AdoptionStrategyEnum#ENHANCE_ALIGNMENT_FLEXIBILITY>,
        <https://w3id.org/lmodel/slsa/AdoptionStrategyEnum#IMPROVE_VERIFICATION_PROCESS>,
        <https://w3id.org/lmodel/slsa/AdoptionStrategyEnum#PROVIDE_DETAILED_DOCUMENTATION>,
        <https://w3id.org/lmodel/slsa/AdoptionStrategyEnum#STREAMLINE_PROVENANCE_GENERATION> .

slsa:BuildEnvLevelEnum a owl:Class ;
    rdfs:label "BuildEnvLevelEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/slsa/BuildEnvLevelEnum#SLSA_BUILD_ENV_LEVEL_0> <https://w3id.org/lmodel/slsa/BuildEnvLevelEnum#SLSA_BUILD_ENV_LEVEL_1> <https://w3id.org/lmodel/slsa/BuildEnvLevelEnum#SLSA_BUILD_ENV_LEVEL_2> <https://w3id.org/lmodel/slsa/BuildEnvLevelEnum#SLSA_BUILD_ENV_LEVEL_3> ) ;
    skos:definition "SLSA Build Environment Track levels for validating the integrity of the compute environment executing builds." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> ;
    linkml:permissible_values <https://w3id.org/lmodel/slsa/BuildEnvLevelEnum#SLSA_BUILD_ENV_LEVEL_0>,
        <https://w3id.org/lmodel/slsa/BuildEnvLevelEnum#SLSA_BUILD_ENV_LEVEL_1>,
        <https://w3id.org/lmodel/slsa/BuildEnvLevelEnum#SLSA_BUILD_ENV_LEVEL_2>,
        <https://w3id.org/lmodel/slsa/BuildEnvLevelEnum#SLSA_BUILD_ENV_LEVEL_3> .

slsa:DependencyLevelEnum a owl:Class ;
    rdfs:label "DependencyLevelEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/slsa/DependencyLevelEnum#SLSA_DEPENDENCY_LEVEL_0> <https://w3id.org/lmodel/slsa/DependencyLevelEnum#SLSA_DEPENDENCY_LEVEL_1> <https://w3id.org/lmodel/slsa/DependencyLevelEnum#SLSA_DEPENDENCY_LEVEL_2> <https://w3id.org/lmodel/slsa/DependencyLevelEnum#SLSA_DEPENDENCY_LEVEL_3> <https://w3id.org/lmodel/slsa/DependencyLevelEnum#SLSA_DEPENDENCY_LEVEL_4> ) ;
    skos:definition "SLSA Dependency Track levels for measuring and controlling risk introduced from third-party dependencies." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> ;
    linkml:permissible_values <https://w3id.org/lmodel/slsa/DependencyLevelEnum#SLSA_DEPENDENCY_LEVEL_0>,
        <https://w3id.org/lmodel/slsa/DependencyLevelEnum#SLSA_DEPENDENCY_LEVEL_1>,
        <https://w3id.org/lmodel/slsa/DependencyLevelEnum#SLSA_DEPENDENCY_LEVEL_2>,
        <https://w3id.org/lmodel/slsa/DependencyLevelEnum#SLSA_DEPENDENCY_LEVEL_3>,
        <https://w3id.org/lmodel/slsa/DependencyLevelEnum#SLSA_DEPENDENCY_LEVEL_4> .

slsa:SourceLevelEnum a owl:Class ;
    rdfs:label "SourceLevelEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/slsa/SourceLevelEnum#SLSA_SOURCE_LEVEL_1> <https://w3id.org/lmodel/slsa/SourceLevelEnum#SLSA_SOURCE_LEVEL_2> <https://w3id.org/lmodel/slsa/SourceLevelEnum#SLSA_SOURCE_LEVEL_3> <https://w3id.org/lmodel/slsa/SourceLevelEnum#SLSA_SOURCE_LEVEL_4> ) ;
    skos:definition "SLSA Source Track levels providing increasing trust in source code provenance and the controls used to create source revisions." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> ;
    linkml:permissible_values <https://w3id.org/lmodel/slsa/SourceLevelEnum#SLSA_SOURCE_LEVEL_1>,
        <https://w3id.org/lmodel/slsa/SourceLevelEnum#SLSA_SOURCE_LEVEL_2>,
        <https://w3id.org/lmodel/slsa/SourceLevelEnum#SLSA_SOURCE_LEVEL_3>,
        <https://w3id.org/lmodel/slsa/SourceLevelEnum#SLSA_SOURCE_LEVEL_4> .

slsa:name a owl:DatatypeProperty ;
    rdfs:label "name" ;
    skos:definition "A local name for a resource within the context of an attestation, or the name of a package, producer, or party." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:SlsaResultEnum a owl:Class ;
    rdfs:label "SlsaResultEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/slsa/SlsaResultEnum#SLSA_BUILD_LEVEL_0> <https://w3id.org/lmodel/slsa/SlsaResultEnum#SLSA_BUILD_LEVEL_1> <https://w3id.org/lmodel/slsa/SlsaResultEnum#SLSA_BUILD_LEVEL_2> <https://w3id.org/lmodel/slsa/SlsaResultEnum#SLSA_BUILD_LEVEL_3> <https://w3id.org/lmodel/slsa/SlsaResultEnum#SLSA_SOURCE_LEVEL_1> <https://w3id.org/lmodel/slsa/SlsaResultEnum#SLSA_SOURCE_LEVEL_2> <https://w3id.org/lmodel/slsa/SlsaResultEnum#SLSA_SOURCE_LEVEL_3> <https://w3id.org/lmodel/slsa/SlsaResultEnum#SLSA_SOURCE_LEVEL_4> ) ;
    skos:definition "A named SLSA result used in Verification Summary Attestations to indicate the verified level of an artifact or its dependencies." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> ;
    linkml:permissible_values <https://w3id.org/lmodel/slsa/SlsaResultEnum#SLSA_BUILD_LEVEL_0>,
        <https://w3id.org/lmodel/slsa/SlsaResultEnum#SLSA_BUILD_LEVEL_1>,
        <https://w3id.org/lmodel/slsa/SlsaResultEnum#SLSA_BUILD_LEVEL_2>,
        <https://w3id.org/lmodel/slsa/SlsaResultEnum#SLSA_BUILD_LEVEL_3>,
        <https://w3id.org/lmodel/slsa/SlsaResultEnum#SLSA_SOURCE_LEVEL_1>,
        <https://w3id.org/lmodel/slsa/SlsaResultEnum#SLSA_SOURCE_LEVEL_2>,
        <https://w3id.org/lmodel/slsa/SlsaResultEnum#SLSA_SOURCE_LEVEL_3>,
        <https://w3id.org/lmodel/slsa/SlsaResultEnum#SLSA_SOURCE_LEVEL_4> .

slsa:id a owl:DatatypeProperty ;
    rdfs:label "id" ;
    skos:definition "A URI uniquely identifying an entity (build platform, verifier, build image, or source repository). The primary trust anchor for consumers." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .

slsa:ResourceDescriptor a owl:Class ;
    rdfs:label "ResourceDescriptor" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:downloadLocation ],
        [ a owl:Restriction ;
            owl:allValuesFrom slsa:DigestSet ;
            owl:onProperty slsa:digest ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:mediaType ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:uri ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:uri ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:digest ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:mediaType ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:annotations ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:downloadLocation ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:mediaType ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:digest ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty slsa:annotations ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty slsa:uri ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty slsa:downloadLocation ] ;
    skos:definition "A reference to a software artifact including its location, digest, and optional metadata. Used throughout SLSA to describe inputs, outputs, and dependencies in provenance attestations." ;
    skos:inScheme <https://w3id.org/lmodel/slsa> .


